# ============================================================
# Lumitrade Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# All required vars must be set or the engine will fail to start.
# Optional vars enable future features when present.
# ============================================================

# ── OANDA (Required) ─────────────────────────────────────────
OANDA_API_KEY_DATA=your-oanda-data-api-key
OANDA_API_KEY_TRADING=your-oanda-trading-api-key
OANDA_ACCOUNT_ID=101-001-XXXXXXXX-XXX
OANDA_ENVIRONMENT=practice

# ── Anthropic / Claude AI (Required) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ── Supabase (Required) ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# ── Telnyx SMS Alerts (Required) ─────────────────────────────
TELNYX_API_KEY=KEY0your-telnyx-api-key
TELNYX_FROM_NUMBER=+1XXXXXXXXXX
ALERT_SMS_TO=+1XXXXXXXXXX

# ── SendGrid Email Alerts (Required) ─────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key
ALERT_EMAIL_TO=your-email@example.com

# ── Instance Configuration (Required) ────────────────────────
INSTANCE_ID=lumitrade-primary
TRADING_MODE=PAPER
LOG_LEVEL=INFO

# ── Error Tracking (Optional) ────────────────────────────────
SENTRY_DSN=

# ── Future Features (Optional — leave empty to disable) ──────
# OPENAI_API_KEY=              # Multi-model AI consensus (Phase 2)
# NEWS_API_KEY=                # News sentiment analysis (Phase 2)
# STRIPE_SECRET_KEY=           # Marketplace payments (Phase 3)
# STRIPE_CONNECT_CLIENT_ID=    # Copy trading payouts (Phase 3)
# COINBASE_API_KEY=            # Crypto trading (Phase 3)
# ALPACA_API_KEY=              # Stock trading (Phase 3)
# EXPO_PUSH_TOKEN=             # Mobile push notifications (Phase 3)
# RISK_MONITOR_ENABLED=        # AI risk monitor subagent (Phase 2)
