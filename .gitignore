# Environment files — NEVER commit
.env
.env.local
.env.*.local
.env.production
.env.staging
*.env

# Key files
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519

# Secrets and credentials
secrets/
credentials/
*credentials*.json
*service-account*.json

# Log files (may contain sensitive data)
logs/
*.log

# Python
__pycache__/
.venv/
venv/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage

# Node
node_modules/
.next/
out/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Docker
docker-compose.override.yml

# Supabase local
supabase/.temp/
.claude/skills/gstack/

# Tool runtime state — large, never review-relevant
.claude-flow/
.claude/
# .claude/ is entirely local: hooks execute repo-owned Node scripts with broad
# permissions and lifecycle hooks write back to MEMORY.md. Per Codex adversarial
# review 2026-04-26, committing this collapses the trust boundary for any cloner.
.firecrawl/
.gstack/
.superpowers/
.swarm/
.obsidian/

# Large local-only data
graphify-out/
backend/data/

# Plugin / tool config (per-machine, not for review)
.mcp.json
skills-lock.json

# Shell-quoting artifacts (created by accidental bash splits — clean up if seen)
$*
[0-9]
[0-9][0-9]
